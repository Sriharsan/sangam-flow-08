## Public, safe to expose to the browser. Get these from your Supabase project settings > API.
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"
SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

## Server only. Never expose to the browser. Copy this file to .env.local (already gitignored)
## and fill in real values there for local development.

# Supabase project settings > API > service_role secret. Bypasses row level security,
# used only in src/integrations/supabase/client.server.ts for trusted server operations.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

# Google AI Studio (aistudio.google.com/apikey). Powers the live demo chat on /demo.
# Used server side only, never sent to the browser.
GEMINI_API_KEY="your-gemini-api-key"
